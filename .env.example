# -- Application ---------------------------------------------------
APP_ENV=dev
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# -- Database ------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://checkout:password@localhost:5432/checkout_dev

# -- Google Cloud --------------------------------------------------
GCP_PROJECT_ID=checkout-dev
GCS_BUCKET_NAME=checkout-models-dev
GCS_MODEL_PATH=yolo11m/v1/best.pt
GCS_VIDEO_BUCKET=checkout-videos-dev

# -- Model ---------------------------------------------------------
MODEL_LOCAL_PATH=/app/weights/best.pt
MODEL_VERSION=v1

# -- Pipeline hyperparameters -------------------------------------
CONF_THRESHOLD=0.40
DETECTION_FLOOR=0.20
MIN_CONFIRM_FRAMES=6
NMS_IOU_THRESHOLD=0.40
NMS_FAMILY_IOU_THRESHOLD=0.10
CLUSTER_DIST_THRESHOLD=80.0
CLUSTER_EMA_ALPHA=0.5
CLUSTER_MAX_LOST=10
FRAME_SKIP=2

# -- API -----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -- Frontend ------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080